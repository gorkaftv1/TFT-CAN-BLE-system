{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "resolveJsonModule": true,
    "jsx": "react-native",
    "paths": {
      "config/*": ["./src/config/*"],
      "infrastructure/*": ["./src/infrastructure/*"],
      "domain/*": ["./src/domain/*"],
      "stores/*": ["./src/stores/*"],
      "screens/*": ["./src/screens/*"],
      "navigation/*": ["./src/navigation/*"],
      "shared/*": ["./src/shared/*"]
    }
  }
}
