src/.env
src/.env.local
src/.env.*.local
# Packaging
src/**/*.egg-info/
src/**/dist/
src/**/build/
src/**/*.egg
# Testing
src/**/.pytest_cache/
src/**/.coverage
src/**/htmlcov/
src/**/.mypy_cache/
src/**/.ruff_cache/
